#
# If you have OpenRouter keys, set OPENROUTER_API_KEY.
# Otherwise, you can use local Ollama (requires `ollama serve`).
#

# ----------------------------
# OpenRouter (recommended for tool-like reasoning)
# ----------------------------
# OPENROUTER_API_KEY=sk-...
# OPENROUTER_MODEL=openai/gpt-4o-mini

# ----------------------------
# Ollama fallback
# ----------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TEMPERATURE=0

# Server
PORT=8000

# Optional: run without external model calls (use deterministic mock)
# LAB19_MOCK_LLM=1

