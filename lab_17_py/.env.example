# Optional: override API port (default 8000)
# PORT=8000

# LLM API key (required for receipt extraction + SQL chatbot)
OPENROUTER_API_KEY=sk-...

# Postgres connection string (expenses + any other tables)
# Matches the root `db/docker-compose.yml` defaults.
DATABASE_URL=postgresql+psycopg2://langchain:langchain@127.0.0.1:5432/langchain

# Schema-as-vector (pgvector) settings for the SQL chatbot.
# Requires OPENROUTER_API_KEY because embeddings are generated at indexing time.
SCHEMA_RAG_INDEX_ON_STARTUP=1
SCHEMA_VECTOR_TABLE=schema_vectors

# Optional: override embedding model/dimension used for the pgvector column.
# If you keep the default `EMBEDDING_MODEL`, you usually do not need to set DIM.
EMBEDDING_MODEL=openai/text-embedding-3-small
SCHEMA_VECTOR_DIM=1536
